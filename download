import { useState } from 'react'
import { useNotifications } from './NotificationContext.jsx'

const emptyTeacher = { id: '', name: '', department: '', email: '' }

function TeacherManagement() {
  const { teachers, upsertItem, deleteItem } = useNotifications()
  const [form, setForm] = useState(emptyTeacher)

  function submit(event) {
    event.preventDefault()
    upsertItem('teachers', form, 'teacher')
    setForm(emptyTeacher)
  }

  return (
    <section className="page">
      <div className="page-header"><div><p className="eyebrow">Faculty data</p><h1>Teacher Management</h1></div></div>
      <div className="management-grid">
        <form className="panel form-panel" onSubmit={submit}>
          <h2>{form.id ? 'Edit teacher' : 'Add teacher'}</h2>
          <label>Name<input value={form.name} onChange={(event) => setForm({ ...form, name: event.target.value })} required /></label>
          <label>Department<input value={form.department} onChange={(event) => setForm({ ...form, department: event.target.value })} required /></label>
          <label>Email<input type="email" value={form.email} onChange={(event) => setForm({ ...form, email: event.target.value })} required /></label>
          <button className="primary-btn" type="submit">Save teacher</button>
        </form>
        <div className="panel table-wrap">
          <table>
            <thead><tr><th>Name</th><th>Department</th><th>Email</th><th>Actions</th></tr></thead>
            <tbody>
              {teachers.map((teacher) => (
                <tr key={teacher.id}>
                  <td>{teacher.name}</td><td>{teacher.department}</td><td>{teacher.email}</td>
                  <td className="action-cell"><button onClick={() => setForm(teacher)} type="button">Edit</button><button className="danger" onClick={() => deleteItem('teachers', teacher.id, 'Teacher')} type="button">Delete</button></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )
}

export default TeacherManagement
